<hc:Window x:Class="Endfield_Switcher.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Endfield_Switcher"
        mc:Ignorable="d"
        Title="请输入备注" Height="150" Width="300" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" WindowStyle="ToolWindow">
    <StackPanel Margin="10">
        <TextBlock x:Name="LblMessage"  Text="给数据起个别名吧：" Margin="0,0,0,5"/>
        <TextBox x:Name="TxtInput" Height="25"/>
        <Grid Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="Gray" FontSize="12">
        <Hyperlink NavigateUri="https://github.com/assortest" RequestNavigate="Hyperlink_RequestNavigate">
            关于作者
        </Hyperlink>
            </TextBlock>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="确定" Width="70" Margin="0,0,5,0" IsDefault="True" 
                Click="OkButton_Click" Style="{StaticResource ButtonPrimary}" />

                <Button Content="取消" Width="70" IsCancel="True"
                Click="CancelButton_Click" Style="{StaticResource ButtonDanger}"/>
            </StackPanel>
        </Grid>

    </StackPanel>
</hc:Window>
