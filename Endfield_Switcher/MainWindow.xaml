<hc:Window x:Class="Endfield_Switcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        Title="终末地账号切换器 v1.1" Height="500" Width="400"
        WindowStartupLocation="CenterScreen">
    <!--w-->
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border  Background="#444444" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="当前状态:" Foreground="Gray" FontSize="12"/>
                    <StackPanel Orientation="Horizontal"  Margin="0,5,0,0">
                        <TextBlock x:Name="TxtStatus" Text="未检测到账号信息" Foreground="White" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        <ListView Grid.Row="1" x:Name="AccountList" BorderThickness="1" Background="Transparent">

            <ListView.Resources>
                <ResourceDictionary>
                    <ContextMenu x:Key="ItemContextMenu">
                    <MenuItem Header="修改备注" Click="Rename_Click"/>
                    <MenuItem Header="删除存档" Click="BtnDelete_Click"/>
                </ContextMenu>
                </ResourceDictionary>
            </ListView.Resources>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem"  BasedOn="{StaticResource ListViewItemBaseStyle}" >
                    <Setter Property="ContextMenu" Value="{StaticResource ItemContextMenu}"/>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.View>
                <GridView>
                    <GridViewColumn Header="账户备注" Width="200" DisplayMemberBinding="{Binding DisplayName}"/>
                    <GridViewColumn Header="备份时间" Width="150" DisplayMemberBinding="{Binding LastBackupTime}"/>
                </GridView>
            </ListView.View>

        </ListView>

        <StackPanel Grid.Row="2"  Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="保存" Click="BtnSave_Click" Style="{StaticResource ButtonPrimary}" Margin="5" Width="80"/>
            <Button Content="切换" Click="BtnSwitch_Click" Style="{StaticResource ButtonSuccess}" Margin="5" Width="80"/>
            <Button Content="删除" Click="BtnDelete_Click" Style="{StaticResource ButtonDanger}" Margin="5" Width="80"/>
        </StackPanel>
        <Grid Grid.Row="3" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock  Text="游戏路径:" VerticalAlignment="Center" Foreground="Black" Margin="0,15,0,0"/>
            <TextBox x:Name="TxtGamePath" Text="请输入游戏路径" Grid.Column="1" Foreground="Gray" Margin="10,15,10,0" VerticalAlignment="Center"/>
            <Button Content="浏览" Click="BtnSelectPath_Click" Style="{StaticResource ButtonPrimary}" Grid.Column="2" Margin="5,15,0,0" Width="80"/>

        </Grid>


    </Grid>
</hc:Window>
